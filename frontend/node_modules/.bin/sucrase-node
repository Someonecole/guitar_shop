#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/triton/Projects/guitar-shop (2)/frontend/node_modules/sucrase/bin/node_modules:/home/triton/Projects/guitar-shop (2)/frontend/node_modules/sucrase/node_modules:/home/triton/Projects/guitar-shop (2)/frontend/node_modules:/home/triton/Projects/guitar-shop (2)/node_modules:/home/triton/Projects/node_modules:/home/triton/node_modules:/home/node_modules:/node_modules:/home/triton/Projects/guitar-shop (2)/frontend/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/triton/Projects/guitar-shop (2)/frontend/node_modules/sucrase/bin/node_modules:/home/triton/Projects/guitar-shop (2)/frontend/node_modules/sucrase/node_modules:/home/triton/Projects/guitar-shop (2)/frontend/node_modules:/home/triton/Projects/guitar-shop (2)/node_modules:/home/triton/Projects/node_modules:/home/triton/node_modules:/home/node_modules:/node_modules:/home/triton/Projects/guitar-shop (2)/frontend/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../sucrase/bin/sucrase-node" "$@"
else
  exec node  "$basedir/../sucrase/bin/sucrase-node" "$@"
fi
